{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/pharos-transaction-harness/transaction-request.schema.json",
  "title": "Pharos Transaction Harness Request",
  "type": "object",
  "required": ["chainId", "from", "to", "valueWei", "data"],
  "additionalProperties": false,
  "properties": {
    "chainId": {
      "type": "integer",
      "minimum": 1
    },
    "from": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "to": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "valueWei": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "data": {
      "type": "string",
      "pattern": "^0x([a-fA-F0-9]{2})*$"
    },
    "intent": {
      "type": "string",
      "maxLength": 240
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    }
  }
}
